@model IEnumerable<Supermarket.Web.Models.Product>

@{
    ViewData["Title"] = "Low Stock Report";
}

<h1 class="mb-4">Low Stock Report</h1>

@if (!Model.Any())
{
    <div class="alert alert-success">
        <strong>Excellent!</strong> There are no products with low stock.
    </div>
}
else
{
    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Barcode</th>
                <th>Product</th>
                <th>Supplier</th>
                <th>Category</th>
                <th>Expiry Date</th>
                <th>Price (£)</th>
                <th>Quantity</th>
                <th>Status</th>
            </tr>
        </thead>

        <tbody>

        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Barcode</td>
                <td>@item.Title</td>
                <td>@item.BrandSupplier</td>
                <td>@item.ProductCategory</td>
                <td>@item.ExpiryDate.ToShortDateString()</td>
                <td>£@item.Price</td>
                <td>@item.QuantityInStock</td>

                <td>
                    <span class="badge bg-danger">
                        Low Stock
                    </span>
                </td>
            </tr>
        }

        </tbody>
    </table>
}

<div class="mt-3">
    <a asp-action="Index" class="btn btn-primary">
        Back to Products
    </a>
</div>