@model IEnumerable<Supermarket.Web.Models.Supplier>

<h1>Suppliers</h1>

<p>
    <a asp-action="Create" class="btn btn-success">Add New Supplier</a>
</p>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Supplier Name</th>
            <th>Contact Person</th>
            <th>Phone Number</th>
            <th>Email</th>
            <th>Address</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.SupplierName</td>
            <td>@item.ContactPerson</td>
            <td>@item.PhoneNumber</td>
            <td>@item.Email</td>
            <td>@item.Address</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.SupplierId" class="btn btn-warning btn-sm">Edit</a>
                <a asp-action="Delete" asp-route-id="@item.SupplierId" class="btn btn-danger btn-sm">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>