@model Supermarket.Web.Models.Supplier

<h1>Delete Supplier</h1>

<h4>Are you sure you want to delete this supplier?</h4>

<hr />

<dl class="row">

    <dt class="col-sm-3">Supplier Name</dt>
    <dd class="col-sm-9">@Model.SupplierName</dd>

    <dt class="col-sm-3">Contact Person</dt>
    <dd class="col-sm-9">@Model.ContactPerson</dd>

    <dt class="col-sm-3">Phone Number</dt>
    <dd class="col-sm-9">@Model.PhoneNumber</dd>

    <dt class="col-sm-3">Email</dt>
    <dd class="col-sm-9">@Model.Email</dd>

    <dt class="col-sm-3">Address</dt>
    <dd class="col-sm-9">@Model.Address</dd>

</dl>

<form asp-action="Delete" method="post">

    <input type="hidden" asp-for="SupplierId" />

    <button type="submit" class="btn btn-danger">Delete</button>

    <a asp-action="Index" class="btn btn-secondary">Cancel</a>

</form>