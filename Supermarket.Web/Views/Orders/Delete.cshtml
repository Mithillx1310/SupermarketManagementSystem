@model Supermarket.Web.Models.Order

<h1>Delete Order</h1>

<h4>Are you sure you want to delete this order?</h4>

<hr />

<dl class="row">

    <dt class="col-sm-3">Customer Name</dt>
    <dd class="col-sm-9">@Model.CustomerName</dd>

    <dt class="col-sm-3">Product Name</dt>
    <dd class="col-sm-9">@Model.ProductName</dd>

    <dt class="col-sm-3">Quantity</dt>
    <dd class="col-sm-9">@Model.Quantity</dd>

    <dt class="col-sm-3">Total Price</dt>
    <dd class="col-sm-9">£@Model.TotalPrice</dd>

    <dt class="col-sm-3">Order Date</dt>
    <dd class="col-sm-9">@Model.OrderDate.ToShortDateString()</dd>

</dl>

<form asp-action="Delete" method="post">

    <input type="hidden" asp-for="OrderId" />

    <button type="submit" class="btn btn-danger">Delete</button>

    <a asp-action="Index" class="btn btn-secondary">Cancel</a>

</form>