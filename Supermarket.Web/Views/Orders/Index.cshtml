@model IEnumerable<Supermarket.Web.Models.Order>

@{
    ViewData["Title"] = "Orders";
}

<h1>Orders</h1>

<div class="row mb-4">

    <div class="col-md-3">
        <div class="card bg-primary text-white">
            <div class="card-body text-center">
                <h5>Total Orders</h5>
                <h2>@ViewBag.TotalOrders</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card bg-success text-white">
            <div class="card-body text-center">
                <h5>Total Sales</h5>
                <h2>£@ViewBag.TotalSales</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card bg-warning text-dark">
            <div class="card-body text-center">
                <h5>Items Sold</h5>
                <h2>@ViewBag.TotalItemsSold</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card bg-info text-white">
            <div class="card-body text-center">
                <h5>Average Order</h5>
                <h2>£@ViewBag.AverageOrder</h2>
            </div>
        </div>
    </div>

</div>

<p>
    <a asp-action="Create" class="btn btn-success">Add New Order</a>
    <a asp-action="Report" class="btn btn-info text-white">Sales Report</a>
</p>

<table class="table table-striped table-bordered">

    <thead>
        <tr>
            <th>Customer Name</th>
            <th>Product Name</th>
            <th>Quantity</th>
            <th>Total Price (£)</th>
            <th>Order Date</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.CustomerName</td>
            <td>@item.ProductName</td>
            <td>@item.Quantity</td>
            <td>£@item.TotalPrice</td>
            <td>@item.OrderDate.ToShortDateString()</td>

            <td>
                <a asp-action="Edit"
                   asp-route-id="@item.OrderId"
                   class="btn btn-warning btn-sm">
                    Edit
                </a>

                <a asp-action="Delete"
                   asp-route-id="@item.OrderId"
                   class="btn btn-danger btn-sm">
                    Delete
                </a>
            </td>

        </tr>
    }

    </tbody>

</table>