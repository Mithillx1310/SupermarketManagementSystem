@model IEnumerable<Supermarket.Web.Models.Order>

@{
    ViewData["Title"] = "Dashboard";
}

<h1 class="mb-4">Dashboard</h1>

<div class="alert alert-primary">
    <h4>Welcome to Supermarket Management System</h4>
    <p class="mb-0">Use this dashboard to manage products, suppliers, orders, stock, and sales reports.</p>
</div>

<div class="row mb-4">

    <div class="col-md-4 mb-3">
        <div class="card bg-primary text-white">
            <div class="card-body text-center">
                <h5>Total Products</h5>
                <h2>@ViewBag.TotalProducts</h2>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card bg-success text-white">
            <div class="card-body text-center">
                <h5>Total Suppliers</h5>
                <h2>@ViewBag.TotalSuppliers</h2>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card bg-info text-white">
            <div class="card-body text-center">
                <h5>Total Orders</h5>
                <h2>@ViewBag.TotalOrders</h2>
            </div>
        </div>
    </div>

</div>

<div class="row mb-4">

    <div class="col-md-4 mb-3">
        <div class="card bg-warning text-dark">
            <div class="card-body text-center">
                <h5>Low Stock Products</h5>
                <h2>@ViewBag.LowStockProducts</h2>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card bg-danger text-white">
            <div class="card-body text-center">
                <h5>Expiring Soon</h5>
                <h2>@ViewBag.ExpiringSoonProducts</h2>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card bg-dark text-white">
            <div class="card-body text-center">
                <h5>Total Sales</h5>
                <h2>£@ViewBag.TotalSales</h2>
            </div>
        </div>
    </div>

</div>

<div class="mb-4">
    <a asp-controller="Products" asp-action="Index" class="btn btn-primary">Manage Products</a>
    <a asp-controller="Suppliers" asp-action="Index" class="btn btn-success">Manage Suppliers</a>
    <a asp-controller="Orders" asp-action="Index" class="btn btn-info text-white">Manage Orders</a>
    <a asp-controller="Orders" asp-action="Report" class="btn btn-dark">Sales Report</a>
    <a asp-controller="Products" asp-action="LowStock" class="btn btn-warning">Low Stock Report</a>
</div>

<h3>Recent Orders</h3>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Customer Name</th>
            <th>Product Name</th>
            <th>Quantity</th>
            <th>Total Price (£)</th>
            <th>Order Date</th>
        </tr>
    </thead>

    <tbody>
    @foreach (var order in Model)
    {
        <tr>
            <td>@order.CustomerName</td>
            <td>@order.ProductName</td>
            <td>@order.Quantity</td>
            <td>£@order.TotalPrice</td>
            <td>@order.OrderDate.ToShortDateString()</td>
        </tr>
    }
    </tbody>
</table>